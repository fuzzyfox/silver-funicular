{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "agent-usage-tracker",
  "title": "Agent Usage Tracker",
  "description": "Track your personal Claude (and Codex) subscription usage from Raycast",
  "icon": "icon.png",
  "author": "fuzzyfox",
  "categories": [
    "Developer Tools",
    "Productivity"
  ],
  "license": "MPL-2.0",
  "commands": [
    {
      "name": "view-usage",
      "title": "View Agent Usage",
      "description": "View your remaining Claude and Codex subscription rate-limit windows",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.65.0",
    "@raycast/utils": "^1.12.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.8",
    "@types/node": "22.13.0",
    "@types/react": "19.0.10",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
